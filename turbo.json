{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "noUpdateNotifier": true,
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".output/**", ".vercel/output/**", "dist/**"],
      "env": [
        "VERCEL",
        "VERCEL_ENV",
        "CONVEX_DEPLOY_KEY",
        "WEB_PORT",
        "WORKOS_CLIENT_ID",
        "WORKOS_API_KEY",
        "WORKOS_COOKIE_PASSWORD",
        "VITE_CONVEX_URL"
      ]
    },
    "codegen": {
      "dependsOn": ["^codegen"],
      "outputs": ["src/generated.ts", "_generated/**", "src/component/_generated/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:lib": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "dev:setup": {
      "cache": false,
      "persistent": true
    },
    "test:integration": {
      "cache": false
    },
    "test:unit": {
      "cache": false
    }
  }
}
