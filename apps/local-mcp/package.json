{
  "name": "@tokenspace/local-mcp",
  "version": "0.2.2",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tokenspace-ai/tokenspace.git",
    "directory": "apps/local-mcp"
  },
  "homepage": "https://github.com/tokenspace-ai/tokenspace/tree/main/apps/local-mcp#readme",
  "bugs": {
    "url": "https://github.com/tokenspace-ai/tokenspace/issues"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "system",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "tokenspace-local-mcp": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run build.ts",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly",
    "prepack": "bun --cwd ../../packages/types build && bun --cwd ../../packages/system-content build && bun --cwd ../../packages/sdk build && bun --cwd ../../packages/compiler build && bun --cwd ../../packages/runtime-core build && bun run clean && bun run build && bun run build:types",
    "run:cli": "bun run src/cli.ts",
    "dev": "bun --hot src/cli.ts",
    "inspect:testing": "bun run build && npx @modelcontextprotocol/inspector bun dist/cli.js ../../examples/testing",
    "inspect:demo": "bun run build && npx @modelcontextprotocol/inspector bun dist/cli.js ../../examples/demo",
    "test:unit": "bun test ./src",
    "test:integration": "bun test ./integration --timeout 10000",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.3.9"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tokenspace/compiler": "^0.2.2",
    "@tokenspace/sdk": "^0.2.2",
    "@tokenspace/runtime-core": "^0.2.2",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "esbuild": "^0.27.4",
    "just-bash": "^2.13.0",
    "lucide-react": "^0.577.0",
    "react": "^19",
    "react-dom": "^19",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2"
  }
}
