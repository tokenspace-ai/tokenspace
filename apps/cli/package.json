{
  "name": "tokenspace",
  "version": "0.2.1",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tokenspace-ai/tokenspace.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/tokenspace-ai/tokenspace/tree/main/apps/cli#readme",
  "bugs": {
    "url": "https://github.com/tokenspace-ai/tokenspace/issues"
  },
  "type": "module",
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "assets",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "tokenspace": "./dist/cli.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly",
    "prepack": "bun run clean && bun run build",
    "run:cli": "bun run src/cli.ts",
    "test:unit": "bun test src",
    "typecheck": "tsc --noEmit",
    "symlink": "bash symlink.sh"
  },
  "engines": {
    "bun": ">=1.3.9"
  },
  "dependencies": {
    "@tokenspace/compiler": "^0.2.1",
    "chokidar": "^4.0.3",
    "commander": "^14.0.3",
    "convex": "^1.33.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.5.0",
    "typescript": "^5.7.2"
  }
}
