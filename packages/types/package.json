{
  "name": "@tokenspace/types",
  "version": "0.2.1",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tokenspace-ai/tokenspace.git",
    "directory": "packages/types"
  },
  "homepage": "https://github.com/tokenspace-ai/tokenspace/tree/main/packages/types#readme",
  "bugs": {
    "url": "https://github.com/tokenspace-ai/tokenspace/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly",
    "prepack": "bun run clean && bun run build",
    "codegen": "bun run scripts/build.ts && cd ../.. && bun fix packages/types/",
    "typecheck": "tsc --noEmit",
    "dev:lib": "tsc -w --preserveWatchOutput -p tsconfig.build.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "typescript": "^5.8.3"
  }
}
