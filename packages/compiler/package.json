{
  "name": "@tokenspace/compiler",
  "version": "0.2.1",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tokenspace-ai/tokenspace.git",
    "directory": "packages/compiler"
  },
  "homepage": "https://github.com/tokenspace-ai/tokenspace/tree/main/packages/compiler#readme",
  "bugs": {
    "url": "https://github.com/tokenspace-ai/tokenspace/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "tokenspace-compiler": "./dist/cli.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly",
    "prepack": "bun --cwd ../types build && bun --cwd ../system-content build && bun run clean && bun run build",
    "typecheck": "tsc --noEmit",
    "test:unit": "bun test"
  },
  "engines": {
    "bun": ">=1.3.9"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@tokenspace/system-content": "^0.2.1",
    "@tokenspace/types": "^0.2.1",
    "esbuild": "^0.25.10",
    "typescript": "^5.8.3",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9"
  }
}
