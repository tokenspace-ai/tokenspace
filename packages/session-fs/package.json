{
  "name": "@tokenspace/session-fs",
  "version": "0.3.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tokenspace-ai/tokenspace.git",
    "directory": "packages/session-fs"
  },
  "homepage": "https://github.com/tokenspace-ai/tokenspace/tree/main/packages/session-fs#readme",
  "bugs": {
    "url": "https://github.com/tokenspace-ai/tokenspace/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "bun run clean && bun run build",
    "test:unit": "bun test",
    "typecheck": "tsc --noEmit",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev:lib": "tsc -w --preserveWatchOutput -p tsconfig.build.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@tokenspace/backend": "^0.3.0",
    "just-bash": "^2.13.0"
  },
  "peerDependencies": {
    "convex": "^1.31.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "convex": "^1.33.0",
    "typescript": "^5.8.3"
  }
}
