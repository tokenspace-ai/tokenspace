{
  "name": "tokenspace-monorepo",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tokenspace-ai/tokenspace.git"
  },
  "homepage": "https://github.com/tokenspace-ai/tokenspace#readme",
  "bugs": {
    "url": "https://github.com/tokenspace-ai/tokenspace/issues"
  },
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "examples/*",
      "packages/*",
      "services/*",
      "scripts"
    ],
    "catalog": {
      "convex": "^1.32.0"
    }
  },
  "scripts": {
    "dev:setup": "bun run scripts/dev_setup.ts",
    "shuffle-ports": "bun run scripts/shuffle-ports.ts",
    "update-convex-binary": "bun run scripts/update-convex-binary-version.ts",
    "dev": "bun run scripts/dev.ts --seed",
    "dev:stop": "bun run scripts/dev.ts stop",
    "db:nuke": "bun run scripts/nuke-db.ts",
    "db:seed": "bun run scripts/seed.ts",
    "db:seed:update": "bun run scripts/seed.ts --update",
    "llm:recordings:export": "bun run scripts/export-llm-recordings.ts",
    "llm:recordings:seed": "bun run scripts/seed-llm-recordings.ts",
    "build": "turbo build",
    "build:public-packages": "bun --cwd packages/types build && bun --cwd packages/system-content build && bun --cwd packages/sdk build && bun --cwd packages/compiler build && bun --cwd packages/runtime-core build && bun --cwd apps/cli build && bun --cwd apps/local-mcp build && bun --cwd apps/local-mcp build:types",
    "codegen": "turbo codegen",
    "dev:web": "bun scripts/update-convex-url.ts && turbo -F web dev",
    "dev:docs": "turbo -F @tokenspace/docs dev",
    "dev:server": "turbo -F @tokenspace/backend dev",
    "check": "biome check .",
    "check:ci": "biome ci . --reporter=github",
    "check:fix": "biome check --fix .",
    "fix": "biome check --fix --unsafe .",
    "format": "biome format --write .",
    "lint": "biome lint . && turbo lint",
    "lint:fix": "biome lint . --fix && turbo lint -- --fix",
    "lint:repo": "bunx sherif@latest",
    "lint:repo:fix": "bunx sherif@latest --fix",
    "test:unit": "turbo test:unit",
    "test:integration": "turbo test:integration",
    "typecheck": "turbo typecheck",
    "tokenspace": "bun run apps/cli/src/cli.ts",
    "symlink:cli": "bash apps/cli/symlink.sh",
    "local-mcp:install": "bun run scripts/install-local-mcp.ts",
    "local-mcp:inspect:testing": "bun --cwd apps/local-mcp inspect:testing",
    "local-mcp:inspect:demo": "bun --cwd apps/local-mcp inspect:demo",
    "release:check": "bun run scripts/check-public-packages.ts && bun run scripts/release-pack-smoke.ts --dry-run",
    "release:version": "changeset version && bun install",
    "release:publish": "changeset publish",
    "release:pack-smoke": "bun run scripts/release-pack-smoke.ts",
    "release:full": "bun install && bun run release:check && bun run release:pack-smoke && npm login && bun run release:publish",
    "clean:repo": "[ -f .env ] && mv .env .env.bak; git clean -fdX; [ -f .env.bak ] && mv .env.bak .env || true",
    "postinstall": "bun run build:public-packages",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@biomejs/biome": "^2.4.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "turbo": "^2.8.10"
  },
  "lint-staged": {
    "*": [
      "biome check --fix --no-errors-on-unmatched"
    ]
  },
  "packageManager": "bun@1.3.9"
}
