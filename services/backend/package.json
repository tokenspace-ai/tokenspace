    "@ai-sdk/openai": "^3.0.41",
    "@convex-dev/resend": "^0.2.3",
    "@tokenspace/compiler": "workspace:*",
    "@tokenspace/config": "workspace:*",
    "@tokenspace/convex-durable-agents": "workspace:*",
    "@tokenspace/convex-local-dev": "workspace:*",
    "@tokenspace/system-content": "workspace:*",
    "@tokenspace/types": "workspace:*",
    "@types/node": "^25.5.0",
    "@workos-inc/node": "^8.9.0",
    "ai": "^6.0.116",
    "esbuild-wasm": "0.27.4",
    "just-bash": "^2.13.0",
    "typescript": "^5.9.2",
    "yaml": "^2.8.2",
    "zod": "^4.3.5"
  },
  "dependencies": {
    "convex": "catalog:"
  }
