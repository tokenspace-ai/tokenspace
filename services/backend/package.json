  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tokenspace-ai/tokenspace.git",
    "directory": "services/backend"
  },
  "homepage": "https://github.com/tokenspace-ai/tokenspace/tree/main/services/backend#readme",
  "bugs": {
    "url": "https://github.com/tokenspace-ai/tokenspace/issues"
  },
  "type": "module",
  "exports": {
    "./convex/_generated/api": {
      "types": "./convex/_generated/api.d.ts",
      "default": "./convex/_generated/api.js"
    },
    "./convex/_generated/dataModel": {
      "types": "./convex/_generated/dataModel.d.ts"
    },
    "./convex/_generated/server": {
      "types": "./convex/_generated/server.d.ts",
      "default": "./convex/_generated/server.js"
    }
  },
  "files": [
    "convex/_generated",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
